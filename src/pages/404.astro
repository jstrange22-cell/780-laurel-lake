---
import Base from "~/layouts/Base.astro";
import { property } from "~/data/property";
---

<Base title={`Not Found · ${property.address.line1}`}>
  <main class="flex min-h-[100svh] items-center justify-center bg-ink-950 px-6 py-24">
    <div class="text-center">
      <p class="text-eyebrow text-gold-300">404</p>
      <h1 class="text-display mt-4 text-5xl text-ink-50 sm:text-7xl">Wrong turn.</h1>
      <p class="mt-4 max-w-md text-ink-300">The page you're looking for doesn't exist.</p>
      <a href="/" class="btn btn-gold mt-10 inline-flex" data-magnetic>
        Back to {property.address.line1}
      </a>
    </div>
  </main>
</Base>
