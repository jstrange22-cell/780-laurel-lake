---
import { property, computed } from "~/data/property";
import ContactForm from "~/components/ContactForm";
---

<section
  id="contact"
  class="relative bg-ink-950 py-20 sm:py-28"
  aria-labelledby="contact-heading"
>
  <div class="container-x">
    <div class="grid grid-cols-1 gap-12 md:grid-cols-12 md:gap-16">
      <div class="md:col-span-5">
        <p class="text-eyebrow reveal mb-4">Schedule a Tour</p>
        <h2 id="contact-heading" class="text-display reveal text-4xl text-ink-50 sm:text-5xl">
          Walk it. Stand on the dock. Smell the lake air.
        </h2>
        <p class="reveal mt-6 max-w-prose text-ink-300">
          The home shows beautifully in person. Send a request and we'll
          coordinate a private showing — typically within 24 hours.
        </p>

        {property.agent.name && (
          <div class="mt-10 flex items-center gap-4">
            {property.agent.photo && (
              <img
                src={property.agent.photo}
                alt={property.agent.name}
                width="56"
                height="56"
                loading="lazy"
                class="h-14 w-14 rounded-full object-cover"
              />
            )}
            <div>
              <p class="text-display text-lg text-ink-50">{property.agent.name}</p>
              {property.agent.brokerage && (
                <p class="text-stat text-ink-400">{property.agent.brokerage}</p>
              )}
            </div>
          </div>
        )}
      </div>

      <div class="md:col-span-7">
        <ContactForm
          webhookUrl={property.contactWebhookUrl}
          propertyAddress={computed.fullAddress()}
          client:visible
        />
      </div>
    </div>
  </div>
</section>
