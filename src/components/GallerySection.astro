---
import { manifest } from "~/lib/manifest";
import InteriorGallery from "~/components/InteriorGallery";

// Curated gallery: interleave exteriors near the start, interiors fill the body.
// Order: 5,6,7,8,9 (exterior approach) → 10..53 (interior tour) → 56,58,60,61,62 (exterior detail)
const order = [
  ...[5, 6, 7, 8, 9],
  ...Array.from({ length: 53 - 10 + 1 }, (_, i) => i + 10),
  ...[56, 58, 60, 61, 62],
];
const images = order
  .map((id) => manifest.images.find((i) => i.id === id))
  .filter((i): i is NonNullable<typeof i> => Boolean(i));
---

<section
  id="gallery"
  class="relative bg-ink-950 py-20 sm:py-28"
  aria-labelledby="gallery-heading"
>
  <div class="container-x mb-10 sm:mb-14">
    <p class="text-eyebrow reveal mb-4">Inside the Home</p>
    <h2 id="gallery-heading" class="text-display reveal max-w-3xl text-4xl text-ink-50 sm:text-5xl">
      Every room, in detail.
    </h2>
    <p class="reveal mt-4 max-w-prose text-ink-300">
      Tap any image to enter the lightbox — pinch, zoom, and arrow through
      {images.length} curated photographs.
    </p>
  </div>

  <div class="container-x">
    <InteriorGallery images={images} client:visible />
  </div>
</section>
