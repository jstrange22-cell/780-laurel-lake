---
import { manifest, imagesByIds } from "~/lib/manifest";
import SmartImage from "~/components/SmartImage.astro";

const drones = imagesByIds(manifest.byType.drone);
---

<section
  id="aerials"
  class="relative bg-ink-950 py-20 sm:py-28"
  aria-labelledby="aerials-heading"
>
  <div class="container-x mb-10">
    <p class="text-eyebrow reveal mb-4">From Above</p>
    <h2 id="aerials-heading" class="text-display reveal max-w-3xl text-4xl text-ink-50 sm:text-5xl">
      The land speaks first.
    </h2>
    <p class="reveal mt-4 max-w-prose text-ink-300">
      Drag, scroll, or arrow your way through the property — captured at golden
      hour above Laurel Lake.
    </p>
  </div>

  <!-- Horizontal scroll rail -->
  {
    drones.length > 0 ? (
      <div
        data-aerial-rail
        class="relative w-full overflow-x-auto overflow-y-hidden snap-x snap-mandatory pb-8"
        tabindex="0"
        aria-roledescription="carousel"
      >
        <div class="flex w-max gap-3 px-[clamp(1.25rem,4vw,3rem)]">
          {drones.map((img, i) => (
            <figure
              class="relative h-[60vh] min-h-[420px] flex-none snap-start overflow-hidden rounded-xl bg-ink-800"
              style={`width: ${
                img.aspect > 1.6 ? "min(82vw, 1100px)" : img.aspect > 1.3 ? "min(72vw, 940px)" : "min(56vw, 720px)"
              }; aspect-ratio: ${img.aspect};`}
              data-aerial-slide
              aria-label={`Aerial photo ${i + 1} of ${drones.length}`}
            >
              <SmartImage image={img} fill loading={i < 2 ? "eager" : "lazy"} sizes="80vw" />
              <figcaption class="text-stat absolute bottom-4 left-4 rounded-full bg-ink-950/60 px-3 py-1 text-ink-100 backdrop-blur">
                {String(i + 1).padStart(2, "0")} / {String(drones.length).padStart(2, "0")}
              </figcaption>
            </figure>
          ))}
          <div class="w-1 flex-none"></div>
        </div>
      </div>
    ) : (
      <div class="container-x">
        <p class="text-ink-400">Aerial gallery loading…</p>
      </div>
    )
  }

  <div class="container-x mt-6">
    <p class="text-stat text-ink-500">
      ← Drag · Scroll · Arrow keys →
    </p>
  </div>
</section>

<script is:inline>
  // Keyboard arrow nav for the rail + horizontal scroll on vertical wheel
  document.addEventListener("DOMContentLoaded", () => {
    const rail = document.querySelector("[data-aerial-rail]");
    if (!(rail instanceof HTMLElement)) return;
    const slides = Array.from(rail.querySelectorAll("[data-aerial-slide]"));
    if (slides.length === 0) return;

    const scrollToIndex = (i) => {
      const clamped = Math.max(0, Math.min(slides.length - 1, i));
      const el = slides[clamped];
      if (el instanceof HTMLElement) {
        rail.scrollTo({ left: el.offsetLeft - 32, behavior: "smooth" });
      }
    };
    const currentIndex = () => {
      const x = rail.scrollLeft + rail.clientWidth / 2;
      let best = 0;
      let bestDist = Infinity;
      slides.forEach((s, i) => {
        if (s instanceof HTMLElement) {
          const c = s.offsetLeft + s.offsetWidth / 2;
          const d = Math.abs(c - x);
          if (d < bestDist) {
            bestDist = d;
            best = i;
          }
        }
      });
      return best;
    };

    rail.addEventListener("keydown", (e) => {
      if (e.key === "ArrowRight") {
        e.preventDefault();
        scrollToIndex(currentIndex() + 1);
      } else if (e.key === "ArrowLeft") {
        e.preventDefault();
        scrollToIndex(currentIndex() - 1);
      }
    });
  });
</script>
