---
import { property, computed } from "~/data/property";
const year = new Date().getFullYear();
const b = property.brokerage;
const fullBrokerageAddress = `${b.address.line1}${b.address.line2 ? `, ${b.address.line2}` : ""}, ${b.address.city}, ${b.address.state} ${b.address.zip}`;
const directionsHref = `https://maps.google.com/?q=${encodeURIComponent(fullBrokerageAddress)}`;
const telLink = b.phone ? `tel:${b.phone.replace(/\s|\(|\)|-/g, "")}` : "";
---

<footer class="relative border-t border-white/8 bg-ink-950 pt-16 pb-10">
  <div class="container-x">
    <!-- Brokerage card — prominent, required for TN TREC + Fair Housing compliance -->
    <div class="surface mb-12 grid grid-cols-1 gap-8 rounded-2xl p-8 sm:p-10 md:grid-cols-12">
      <div class="md:col-span-6">
        <p class="text-eyebrow mb-3 text-gold-300">Presented By</p>
        <p class="text-display text-2xl text-ink-50 sm:text-3xl">{b.name}</p>
        {b.parent && <p class="text-stat mt-2 text-ink-300">{b.parent}</p>}

        <address class="mt-6 not-italic">
          <p class="text-ink-100">{b.address.line1}</p>
          {b.address.line2 && <p class="text-ink-100">{b.address.line2}</p>}
          <p class="text-ink-100">
            {b.address.city}, {b.address.state} {b.address.zip}
          </p>
          <a
            href={directionsHref}
            target="_blank"
            rel="noopener noreferrer"
            class="text-stat mt-2 inline-block text-gold-200 hover:text-gold-100"
          >
            Get Directions →
          </a>
        </address>
      </div>

      <div class="md:col-span-3">
        <p class="text-eyebrow mb-3">Contact</p>
        {b.phone && (
          <a href={telLink} class="text-ink-100 hover:text-gold-200 block">
            {b.phone}
          </a>
        )}
        {b.email && (
          <a href={`mailto:${b.email}`} class="text-ink-200 hover:text-gold-200 mt-1 block break-all text-sm">
            {b.email}
          </a>
        )}
        {b.website && (
          <a
            href={b.website}
            target="_blank"
            rel="noopener noreferrer"
            class="text-ink-200 hover:text-gold-200 mt-1 block text-sm"
          >
            {b.website.replace(/^https?:\/\//, "")}
          </a>
        )}
      </div>

      <div class="md:col-span-3">
        <p class="text-eyebrow mb-3">Licensing</p>
        {b.firmLicense ? (
          <p class="text-stat text-ink-200">TN Firm License #{b.firmLicense}</p>
        ) : (
          <p class="text-stat text-ink-500">TN Firm License #—</p>
        )}
        {b.principalBroker && (
          <p class="text-stat mt-2 text-ink-300">
            Principal Broker: {b.principalBroker}
            {b.principalBrokerLicense && ` · #${b.principalBrokerLicense}`}
          </p>
        )}
        {property.agent.licenseNumber && (
          <p class="text-stat mt-2 text-ink-300">
            Listing Agent: {property.agent.name} · #{property.agent.licenseNumber}
          </p>
        )}
        <p class="text-stat mt-2 text-ink-500">Each office independently owned & operated</p>
      </div>
    </div>

    <!-- Property + nav -->
    <div class="grid grid-cols-1 gap-10 md:grid-cols-12">
      <div class="md:col-span-5">
        <p class="text-display text-2xl text-ink-50">{property.address.line1}</p>
        <p class="text-stat mt-2 text-ink-400">
          {property.address.city}, {property.address.state} {property.address.zip}
        </p>
        {property.mlsNumber && (
          <p class="text-stat mt-3 text-ink-300">MLS #{property.mlsNumber}</p>
        )}
      </div>

      <div class="md:col-span-3">
        <p class="text-eyebrow mb-4">Visit</p>
        <ul class="space-y-2 text-sm">
          <li><a href="#story" class="text-ink-200 hover:text-gold-200">The Home</a></li>
          <li><a href="#aerials" class="text-ink-200 hover:text-gold-200">Aerials</a></li>
          <li><a href="#gallery" class="text-ink-200 hover:text-gold-200">Gallery</a></li>
          <li><a href="#reel" class="text-ink-200 hover:text-gold-200">Reel</a></li>
          <li><a href="#lake" class="text-ink-200 hover:text-gold-200">Lake</a></li>
          <li><a href="#location" class="text-ink-200 hover:text-gold-200">Location</a></li>
          <li><a href="#contact" class="text-ink-200 hover:text-gold-200">Contact</a></li>
        </ul>
      </div>

      <div class="md:col-span-4">
        <p class="text-eyebrow mb-4">Inquire</p>
        {property.agent.name && (
          <p class="text-display text-lg text-ink-50">{property.agent.name}</p>
        )}
        {property.agent.email && (
          <a
            href={`mailto:${property.agent.email}`}
            class="text-ink-100 hover:text-gold-200 mt-1 block break-all text-sm"
          >
            {property.agent.email}
          </a>
        )}
        {property.agent.phone && (
          <a
            href={`tel:${property.agent.phone.replace(/\s|\(|\)|-/g, "")}`}
            class="text-ink-100 hover:text-gold-200 mt-1 block text-sm"
          >
            {property.agent.phone}
          </a>
        )}
      </div>
    </div>

    <!-- Equal Housing + Fair Housing line -->
    <div class="mt-14 flex flex-col-reverse items-start justify-between gap-6 border-t border-white/5 pt-8 md:flex-row md:items-center">
      <p class="text-stat text-ink-500">
        © {year} {b.name} · {computed.fullAddress()}
      </p>
      <div class="flex items-center gap-3">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" aria-hidden="true">
          <rect x="2" y="2" width="20" height="20" rx="2" stroke="currentColor" stroke-width="1.4" class="text-gold-300" />
          <path d="M12 6.5L5 11.5h2v6h10v-6h2L12 6.5zM10 17v-3h4v3" stroke="currentColor" stroke-width="1.2" class="text-gold-300" fill="none" />
          <line x1="6" y1="20.5" x2="18" y2="20.5" stroke="currentColor" stroke-width="0.6" class="text-gold-300" />
        </svg>
        <div>
          <p class="text-stat text-gold-300">Equal Housing Opportunity</p>
          <p class="text-stat text-ink-500">Fair Housing Act</p>
        </div>
      </div>
    </div>

    <!-- Disclaimers — RESPA / Fair Housing / data accuracy -->
    <p class="text-stat mt-6 max-w-4xl leading-relaxed text-ink-600">
      {property.disclaimers}
    </p>
    <p class="text-stat mt-3 max-w-4xl leading-relaxed text-ink-700">
      Real estate brokerage services provided by {b.parent ? `${b.parent} — ${b.name}` : b.name}.
      We comply with the Fair Housing Act and do not discriminate on the basis of race, color,
      religion, national origin, sex, familial status, disability, or any other class protected
      by federal, state, or local law. Information collected through our contact form is used
      solely to respond to your inquiry and is never sold or shared with third parties for
      marketing purposes. We do not pay or receive undisclosed fees or kickbacks for the
      referral of settlement services in connection with this listing (RESPA §8).
    </p>
  </div>
</footer>
