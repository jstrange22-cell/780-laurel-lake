---
import "~/styles/global.css";
import { property, computed } from "~/data/property";
import { buildJsonLd, pageTitle, pageDescription } from "~/lib/seo";

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
}

const { title, description, ogImage }: Props = Astro.props;
const canonical = new URL(Astro.url.pathname, Astro.site ?? "https://780laurellake.com").toString();
const ogImageUrl = new URL(ogImage ?? "/og-image.jpg", Astro.site ?? "https://780laurellake.com").toString();
const finalTitle = title ?? pageTitle();
const finalDesc = description ?? pageDescription();
const jsonld = buildJsonLd(canonical, ogImageUrl);
---

<!doctype html>
<html lang="en" data-theme="ink">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="color-scheme" content="dark" />
    <meta name="theme-color" content="#0c0a07" />

    <link rel="icon" href={`${import.meta.env.BASE_URL.replace(/\/$/, "")}/favicon.svg`} type="image/svg+xml" />
    <link rel="canonical" href={canonical} />

    <title>{finalTitle}</title>
    <meta name="description" content={finalDesc} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={finalTitle} />
    <meta property="og:description" content={finalDesc} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:locale" content="en_US" />
    <meta property="og:site_name" content={computed.fullAddress()} />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={finalTitle} />
    <meta name="twitter:description" content={finalDesc} />
    <meta name="twitter:image" content={ogImageUrl} />

    <!-- Structured data -->
    <script is:inline type="application/ld+json" set:html={JSON.stringify(jsonld)} />

    <!-- Geo meta -->
    <meta name="geo.region" content={`US-${property.address.state}`} />
    <meta name="geo.placename" content={property.address.city} />
    <meta name="geo.position" content={`${property.address.lat};${property.address.lng}`} />
    <meta name="ICBM" content={`${property.address.lat}, ${property.address.lng}`} />

    <!-- Performance hints -->
    <link
      rel="preload"
      as="image"
      href={`${import.meta.env.BASE_URL.replace(/\/$/, "")}/img/property/prop-001-1920.avif`}
      type="image/avif"
    />
  </head>

  <body class="bg-ink-950 text-ink-100 antialiased">
    <slot />

    <script>
      import { bootMotion } from "~/lib/motion";
      const start = () => bootMotion();
      if (document.readyState === "loading") {
        document.addEventListener("DOMContentLoaded", start, { once: true });
      } else {
        start();
      }
    </script>
  </body>
</html>
