{
  "name": "780-laurel-lake",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "780 Laurel Lake Circle, Madisonville TN — single-property listing microsite",
  "scripts": {
    "assets:images": "tsx scripts/prepare-images.ts",
    "assets:video": "tsx scripts/prepare-video.ts",
    "assets": "pnpm run assets:images && pnpm run assets:video",
    "dev": "astro dev --host",
    "build": "pnpm run assets && astro build",
    "build:fast": "astro build",
    "preview": "astro preview --host",
    "typecheck": "astro check"
  },
  "dependencies": {
    "@astrojs/check": "^0.9.4",
    "@astrojs/react": "^4.4.0",
    "@fontsource-variable/fraunces": "^5.2.9",
    "@fontsource-variable/inter": "^5.2.8",
    "@fontsource/jetbrains-mono": "^5.2.8",
    "@tailwindcss/vite": "^4.1.13",
    "@types/leaflet": "^1.9.20",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "astro": "^5.16.0",
    "blurhash": "^2.0.5",
    "gsap": "^3.13.0",
    "leaflet": "^1.9.4",
    "lenis": "^1.3.13",
    "photoswipe": "^5.4.4",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "tailwindcss": "^4.1.13",
    "typescript": "^5.9.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "ffmpeg-static": "^5.2.0",
    "ffprobe-static": "^3.1.0",
    "sharp": "^0.34.0",
    "tsx": "^4.20.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "sharp",
      "esbuild",
      "@astrojs/compiler",
      "ffmpeg-static",
      "ffprobe-static"
    ]
  }
}
